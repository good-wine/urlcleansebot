# --- Telegram Bot Configuration ---
# Get your bot token from @BotFather on Telegram
TELOXIDE_TOKEN=your_bot_token_here
BOT_USERNAME=YourBotUsername
ADMIN_ID=your_telegram_user_id

# --- Database Configuration ---
# The bot now uses sqlx::Any, supporting both SQLite and PostgreSQL.
# For SQLite (Local Development):
DATABASE_URL=sqlite:bot.db?mode=rwc
# For PostgreSQL/Supabase (Production):
# DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres

# --- HTTP / Webhook Configuration ---
# The bot runs in long-polling mode by default.
# Set WEBHOOK_URL and WEBHOOK_SECRET to enable Telegram webhook mode.
# Optional: SERVER_ADDR can override the bind address for webhook mode.
# Example: 0.0.0.0:8080
#SERVER_ADDR=0.0.0.0:8080

# --- Webhook Mode (Optional) ---
# Public HTTPS URL where Telegram will POST updates.
# Leave empty to keep long-polling (recommended for local dev).
# Example: https://urlcleansebot.example.com/webhook
#WEBHOOK_URL=
# Random token used to verify the X-Telegram-Bot-Api-Secret-Token header.
# Generate with: openssl rand -hex 32   (16-256 chars, only A-Z a-z 0-9 _ -)
# REQUIRED when WEBHOOK_URL is set.
#WEBHOOK_SECRET=
# TCP port the embedded HTTP server binds to in webhook mode (default 8080).
#PORT=8080

# --- Observability & Environment ---
# 'development' for pretty logs, 'production' for structured JSON logs.
APP_ENV=development
# Log levels: trace, debug, info, warn, error
RUST_LOG=url_cleanse_bot=info,teloxide=info,axum=info

# --- External Sources ---
CLEARURLS_SOURCE=https://raw.githubusercontent.com/ClearURLs/Rules/refs/heads/master/data.min.json
LIBREDIRECT_URL=https://raw.githubusercontent.com/libredirect/instances/main/data.json
FARSIDE_URL=https://raw.githubusercontent.com/benbusby/farside/refs/heads/main/services-full.json

# --- VirusTotal Integration (Optional) ---
# Real-time malware detection with 70+ antivirus engines
# Get your FREE API key: https://www.virustotal.com/gui/my-apikey
# Free tier: 4 requests/minute, 500/day, 15,500/month
#VIRUSTOTAL_API_KEY=
# Send VirusTotal messages only for suspicious/malicious URLs (default: true)
VIRUSTOTAL_ALERT_ONLY=true

# --- URLScan.io Integration (Optional) ---
# Web reputation scanning and page behavior analysis
# Get API key: https://urlscan.io/user/signup
# URLSCAN_API_KEY=your_urlscan_api_key_here
# Send URLScan.io messages only for suspicious/malicious URLs (default: true)
URLSCAN_ALERT_ONLY=true

# --- AI Deep Scan (Optional) ---
# AI-powered sanitization for complex tracking parameters
# Supports OpenAI and compatible APIs
#AI_API_KEY=your_openai_api_key_here
#AI_API_BASE=https://api.openai.com/v1
#AI_MODEL=gpt-4

# --- Webhook HMAC Security (Optional) ---
# Additional HMAC-SHA256 verification for webhook requests.
# If set, incoming webhooks must include X-Webhook-Signature header.
#WEBHOOK_HMAC_SECRET=your_hmac_secret_here

# --- Linkumori Rules (Optional) ---
# Secondary rule source compatible with Linkumori format.
# Leave empty to use only ClearURLs rules.
#LINKUMORI_SOURCE=https://raw.githubusercontent.com/Linkumori/Linkumori-Addon/main/data/rules.json

# --- Optional Runtime Settings ---
# Inline mode result count (default: 5, max: 50)
#INLINE_MAX_RESULTS=5
